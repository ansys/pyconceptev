{
  "name": "pyconceptev",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.11-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "moby": true,
      "installDockerBuildx": true
    },
    "ghcr.io/devcontainers-contrib/features/poetry:2": {}
  },
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "remoteEnv": {
    "PYOPTISLANG_DISABLE_OPTISLANG_OUTPUT": "true"
  },
  "secrets": {
    "CONCEPTEV_PASSWORD": {
      "description": "Password for the ConceptEV test account (conceptev_testing@ansys.com). Required for integration and e2e tests."
    },
    "LICENSE_SERVER": {
      "description": "Hostname of the Ansys license server for optiSLang e2e tests. Used to construct ANSYSLMD_LICENSE_FILE=1055@<LICENSE_SERVER>."
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.black-formatter",
        "ms-python.isort",
        "ms-python.vscode-pylance"
      ],
      "settings": {
        "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
        "editor.formatOnSave": true,
        "[python]": {
          "editor.defaultFormatter": "ms-python.black-formatter"
        }
      }
    }
  }
}
